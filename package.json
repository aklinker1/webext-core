{
  "name": "webext-core",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "check",
    "check:all": "check && bun run --workspaces --sequential check",
    "test:all": "CI=true bun run --workspaces --sequential test",
    "test:coverage:all": "CI=true bun run --workspaces --sequential test:coverage",
    "build:all": "buildc all",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@aklinker1/buildc": "catalog:",
    "@aklinker1/check": "catalog:",
    "@algolia/client-search": "^4.17.0",
    "@types/bun": "^1.3.14",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "playwright": "^1.47.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "@aklinker1/buildc": "^1.1.5",
    "@aklinker1/check": "^2.4.0",
    "@happy-dom/global-registrator": "^20.9.0",
    "publint": "^0.3.21",
    "tsdown": "^0.22.0",
    "typescript": "^5.5.4"
  },
  "patchedDependencies": {
    "simple-git-hooks@2.13.1": "patches/simple-git-hooks@2.13.1.patch"
  }
}
