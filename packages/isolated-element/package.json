{
  "name": "@webext-core/isolated-element",
  "version": "2.0.1",
  "description": "Isolate content script UI's styles from the parent page. Supports all browsers (Chrome, Firefox, Safari)",
  "keywords": [
    "browser",
    "browser-extension",
    "chrome",
    "chrome-extension",
    "content-script",
    "css",
    "extension",
    "firefox",
    "islolate",
    "safari",
    "styles",
    "web-ext",
    "web-extension",
    "webext"
  ],
  "homepage": "https://github.com/aklinker1/webext-core/tree/main/packages/isolated-element",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aklinker1/webext-core.git",
    "directory": "packages/isolated-element"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "buildc -- tsdown",
    "test": "buildc --deps-only -- bun test",
    "test:coverage": "buildc --deps-only -- bun test --coverage",
    "check": "bun run build && check",
    "prepack": "bun run build"
  },
  "dependencies": {
    "is-potential-custom-element-name": "^1.0.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "catalog:",
    "@types/is-potential-custom-element-name": "^1.0.0",
    "publint": "catalog:",
    "tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "*"
  },
  "buildc": {
    "outDir": "lib"
  }
}
