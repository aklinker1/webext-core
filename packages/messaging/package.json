{
  "name": "@webext-core/messaging",
  "version": "3.0.1",
  "description": "Light weight, type-safe wrapper around the web extension messaging APIs. Supports all browsers (Chrome, Firefox, Safari)",
  "license": "MIT",
  "keywords": [
    "web-extension",
    "browser-extension",
    "chrome-extension",
    "webext",
    "web-ext",
    "chrome",
    "firefox",
    "safari",
    "browser",
    "extension",
    "message",
    "messaging"
  ],
  "homepage": "https://github.com/aklinker1/webext-core/tree/main/packages/messaging",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aklinker1/webext-core.git",
    "directory": "packages/messaging"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib"
  ],
  "engines": {
    "node": "*"
  },
  "sideEffects": false,
  "main": "./lib/index.cjs",
  "module": "./lib/index.mjs",
  "types": "./lib/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./page": {
      "import": {
        "types": "./lib/page.d.mts",
        "default": "./lib/page.mjs"
      },
      "require": {
        "types": "./lib/page.d.cts",
        "default": "./lib/page.cjs"
      }
    }
  },
  "scripts": {
    "build": "buildc -- tsdown",
    "test": "buildc --deps-only -- bun test",
    "test:coverage": "buildc --deps-only -- bun  test --coverage",
    "check": "bun run build && check",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@aklinker1/zero-serialize-error": "^1.0.2",
    "webextension-polyfill": "^0.10.0"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.9.1",
    "@webext-core/fake-browser": "workspace:*",
    "publint": "^0.2.11",
    "tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "buildc": {
    "outDir": "lib"
  }
}
