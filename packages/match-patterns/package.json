{
  "name": "@webext-core/match-patterns",
  "version": "1.0.3",
  "description": "Utilities for working with match patterns.",
  "license": "MIT",
  "keywords": [
    "web-extension",
    "browser-extension",
    "chrome-extension",
    "webext",
    "web-ext",
    "chrome",
    "firefox",
    "safari",
    "browser",
    "extension",
    "match",
    "pattern",
    "content",
    "script"
  ],
  "homepage": "https://github.com/aklinker1/webext-core/tree/main/packages/match-patterns",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aklinker1/webext-core.git",
    "directory": "packages/match-patterns"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib"
  ],
  "engines": {
    "node": "*"
  },
  "sideEffects": false,
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "buildc -- tsdown",
    "test": "buildc --deps-only -- bun test",
    "test:coverage": "buildc --deps-only -- bun test --coverage",
    "check": "bun run build && check",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "publint": "catalog:",
    "tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "buildc": {
    "outDir": "lib"
  }
}
