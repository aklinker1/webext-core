{
  "name": "@webext-core/storage",
  "version": "1.2.1",
  "description": "A type-safe, localStorage-esk wrapper around the web extension storage APIs. Supports all browsers (Chrome, Firefox, Safari, etc)",
  "keywords": [
    "browser",
    "browser-extension",
    "chrome",
    "chrome-extension",
    "extension",
    "firefox",
    "safari",
    "storage",
    "web-ext",
    "web-extension",
    "webext"
  ],
  "homepage": "https://github.com/aklinker1/webext-core/tree/main/packages/storage",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aklinker1/webext-core.git",
    "directory": "packages/storage"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "buildc -- tsdown",
    "test": "buildc --deps-only -- bun test",
    "test:coverage": "buildc --deps-only -- bun test --coverage",
    "check": "bun run build && check",
    "prepack": "bun run build"
  },
  "dependencies": {
    "webextension-polyfill": ">=0.10.0"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.10.5",
    "@webext-core/fake-browser": "workspace:*",
    "publint": "catalog:",
    "tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "*"
  },
  "buildc": {
    "outDir": "lib"
  }
}
