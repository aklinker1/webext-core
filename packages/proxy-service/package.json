{
  "name": "@webext-core/proxy-service",
  "version": "2.0.0",
  "description": "A type-safe wrapper around the web extension messaging APIs that lets you call a function from anywhere, but execute it in the background. Supports all browsers (Chrome, Firefox, Safari, etc)",
  "keywords": [
    "browser",
    "browser-extension",
    "chrome",
    "chrome-extension",
    "extension",
    "firefox",
    "rpc",
    "safari",
    "service",
    "web-ext",
    "web-extension",
    "webext"
  ],
  "homepage": "https://github.com/aklinker1/webext-core/tree/main/packages/proxy-service",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aklinker1/webext-core.git",
    "directory": "packages/proxy-service"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./lib/types.d.mts",
        "default": "./lib/types.mjs"
      },
      "require": {
        "types": "./lib/types.d.cts",
        "default": "./lib/types.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "buildc -- tsdown",
    "test": "buildc --deps-only -- bun test",
    "test:coverage": "buildc --deps-only -- bun test --coverage",
    "check": "bun run build && check",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@types/get-value": "^3.0.3",
    "@types/webextension-polyfill": "^0.9.1",
    "@webext-core/fake-browser": "workspace:*",
    "@webext-core/messaging": "workspace:*",
    "publint": "catalog:",
    "tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "webextension-polyfill": "^0.10.0"
  },
  "peerDependencies": {
    "@webext-core/messaging": ">=1.3.1"
  },
  "engines": {
    "node": "*"
  },
  "buildc": {
    "outDir": "lib"
  }
}
