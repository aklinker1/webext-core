{
  "name": "@webext-core/fake-browser",
  "version": "1.5.1",
  "description": "An in-memory implementation of webextension-polyfill for testing. Supports all test frameworks (Vitest, Jest, etc)",
  "keywords": [
    "browser",
    "browser-extension",
    "chrome",
    "chrome-extension",
    "extension",
    "fake",
    "firefox",
    "jest",
    "mock",
    "safari",
    "testing",
    "vite",
    "web-ext",
    "web-extension",
    "webext",
    "webextension-polyfill"
  ],
  "homepage": "https://github.com/aklinker1/webext-core/tree/main/packages/fake-browser",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aklinker1/webext-core.git",
    "directory": "packages/fake-browser"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.cts",
        "default": "./lib/index.cjs"
      }
    },
    "./auto": {
      "import": {
        "types": "./lib/auto.d.mts",
        "default": "./lib/auto.mjs"
      },
      "require": {
        "types": "./lib/auto.d.cts",
        "default": "./lib/auto.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "buildc -- tsdown",
    "test": "buildc --deps-only -- bun test",
    "test:coverage": "buildc --deps-only -- bun test --coverage",
    "check": "bun run build && check",
    "gen": "bun scripts/generate-base.ts && prettier --write src/base.gen.ts",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@types/webextension-polyfill": "^0.10.5",
    "lodash.merge": "^4.6.2"
  },
  "devDependencies": {
    "@types/lodash.merge": "^4.6.7",
    "publint": "catalog:",
    "ts-morph": "^23.0.0",
    "tsconfig": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "*"
  },
  "buildc": {
    "outDir": "lib"
  }
}
